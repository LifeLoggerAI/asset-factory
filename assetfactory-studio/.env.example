# Asset Factory Studio
# Copy to .env.local for local Next.js development or configure these in Vercel/Fly/Render.

# Runtime
NODE_ENV=development
ASSET_FACTORY_FORCE_LOCAL=true

# Local persistence / Firebase-backed collection names
ASSET_FACTORY_JOBS_COLLECTION=assetFactoryJobs
ASSET_FACTORY_ASSETS_COLLECTION=assetFactoryAssets
ASSET_FACTORY_GENERATED_PREFIX=asset-factory/generated

# Firebase Admin storage/persistence mode.
# When ASSET_FACTORY_FORCE_LOCAL is not true and Firebase Admin initializes,
# jobs/assets/usage go to Firestore and artifacts/manifests go to Cloud Storage.
# Use either explicit service account values or application default credentials.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=

# Auth / API security.
# For local browser Studio UI, keep auth/API guards disabled unless a server-side proxy/session auth layer is added.
# Production should enable a real auth gateway/provider before exposing Studio APIs.
ASSET_FACTORY_REQUIRE_API_KEY=false
ASSET_FACTORY_API_KEY=
ASSET_FACTORY_REQUIRE_AUTH=false
ASSET_FACTORY_REQUIRE_JWT_SIGNATURE=false
ASSET_FACTORY_ALLOW_LEGACY_HEADER_AUTH=false

# Local development JWT signing secret. Replace in every real environment.
JWT_SECRET=change-me-local-only
ASSET_FACTORY_JWT_HS256_SECRET=
ASSET_FACTORY_JWT_ISSUER=
ASSET_FACTORY_JWT_AUDIENCE=
ASSET_FACTORY_AUDIENCE=
ASSET_FACTORY_TENANT_CLAIM=tenantId
ASSET_FACTORY_ROLE_CLAIM=roles

# Optional service-token auth for worker/API calls.
ASSET_FACTORY_SERVICE_TOKEN=
# x-tenant-id, x-user-id, and x-asset-roles headers are honored by the Studio
# RBAC guard only when ASSET_FACTORY_ALLOW_LEGACY_HEADER_AUTH=true.
# Production should prefer signed bearer tokens. Use roles: viewer, creator, publisher, admin, operator.

# Durable queue mode.
# local-inline runs work in-process.
# firestore-queue writes durable queue documents.
# http-task POSTs jobs to ASSET_FACTORY_WORKER_URL.
ASSET_FACTORY_QUEUE_MODE=local-inline
ASSET_FACTORY_WORKER_URL=
ASSET_FACTORY_WORKER_SECRET=

# Per-tenant monthly quota guardrails.
# These are enforced before a job is queued.
# Stripe price metadata can override these with maxMonthlyJobs,
# maxMonthlyUnits, and maxMonthlyCostCents when STRIPE_SECRET_KEY and tenant
# Stripe ids are present.
ASSET_FACTORY_MAX_MONTHLY_JOBS=500
ASSET_FACTORY_MAX_MONTHLY_UNITS=5000
ASSET_FACTORY_MAX_MONTHLY_COST_CENTS=10000

# Media provider configuration.
# local-proof produces deterministic proof assets, including non-production .animatic video timelines.
# Provider-backed graphics/audio/model calls use assetProviderRuntime.ts.
# Provider-backed video calls use the separate fail-closed assetVideoProviderRuntime.ts.
ASSET_FACTORY_MEDIA_PROVIDER=local-proof
OPENAI_API_KEY=
REPLICATE_API_TOKEN=
RUNWAY_API_KEY=
ELEVENLABS_API_KEY=
STABILITY_API_KEY=
FAL_KEY=

# General provider safety guardrails.
ASSET_FACTORY_PROVIDER_TIMEOUT_MS=120000
ASSET_FACTORY_PROVIDER_MAX_BYTES=104857600

# Video-provider transport safety guardrails.
# These apply only when ASSET_FACTORY_MEDIA_PROVIDER is replicate or fal and
# ASSET_FACTORY_VIDEO_MODEL is explicitly set. No video provider is auto-selected.
ASSET_FACTORY_VIDEO_PROVIDER_TIMEOUT_MS=180000
ASSET_FACTORY_VIDEO_PROVIDER_MAX_BYTES=524288000

# Atomic paid-video transaction guardrails.
# Provider-backed video requests require an Idempotency-Key header. The reservation
# is tenant/campaign scoped and occurs before provider dispatch. One attempt is the
# default; failures hold the reservation for operator reconciliation rather than retrying.
ASSET_FACTORY_VIDEO_MAX_JOB_COST_CENTS=2000
ASSET_FACTORY_VIDEO_MAX_CAMPAIGN_COST_CENTS=5000
ASSET_FACTORY_VIDEO_MAX_ATTEMPTS=1

# Provider model IDs by modality.
ASSET_FACTORY_GRAPHICS_MODEL=
ASSET_FACTORY_GRAPHICS_SIZE=1024x1024
ASSET_FACTORY_GRAPHICS_FORMAT=png
ASSET_FACTORY_MODEL3D_MODEL=
ASSET_FACTORY_AUDIO_MODEL=
ASSET_FACTORY_VIDEO_MODEL=
ASSET_FACTORY_OPENAI_VOICE=alloy
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Stripe / billing webhooks if billing is enabled.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional observability and product analytics.
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com