# Asset Factory Studio local/development configuration

# Force local JSON/file storage even when Firebase Admin credentials are present.
ASSET_FACTORY_FORCE_LOCAL=true

# Firebase Admin storage/persistence mode. When ASSET_FACTORY_FORCE_LOCAL is not
# true and Firebase Admin initializes, jobs/assets/usage go to Firestore and
# artifacts/manifests go to Cloud Storage.
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# FIREBASE_STORAGE_BUCKET=

# Local development JWT signing secret. Replace in every real environment.
JWT_SECRET=change-me-local-only

# Optional auth guard. Local dev defaults to false. Production should set this
# true and place a real auth gateway/provider in front of the Studio APIs.
# ASSET_FACTORY_REQUIRE_AUTH=false
# ASSET_FACTORY_SERVICE_TOKEN=
# x-tenant-id, x-user-id, and x-asset-roles headers are honored by the Studio
# RBAC guard when auth is enabled. Use roles: viewer, creator, publisher, admin.

# Durable queue mode. local-inline runs work in-process. firestore-queue writes
# durable queue documents. http-task POSTs jobs to ASSET_FACTORY_WORKER_URL.
# ASSET_FACTORY_QUEUE_MODE=local-inline
# ASSET_FACTORY_WORKER_URL=
# ASSET_FACTORY_WORKER_SECRET=

# Per-tenant monthly quota guardrails. These are enforced before a job is queued.
# Stripe price metadata can override these with maxMonthlyJobs,
# maxMonthlyUnits, and maxMonthlyCostCents when STRIPE_SECRET_KEY and tenant
# Stripe ids are present.
# ASSET_FACTORY_MAX_MONTHLY_JOBS=500
# ASSET_FACTORY_MAX_MONTHLY_UNITS=5000
# ASSET_FACTORY_MAX_MONTHLY_COST_CENTS=10000

# Media provider configuration. local-proof produces deterministic proof assets.
# Provider-backed modes call real media APIs through assetProviderRuntime.ts.
# ASSET_FACTORY_MEDIA_PROVIDER=local-proof
# OPENAI_API_KEY=
# REPLICATE_API_TOKEN=
# ELEVENLABS_API_KEY=
# STABILITY_API_KEY=
# FAL_KEY=

# Provider model IDs by modality.
# ASSET_FACTORY_GRAPHICS_MODEL=
# ASSET_FACTORY_GRAPHICS_SIZE=1024x1024
# ASSET_FACTORY_GRAPHICS_FORMAT=png
# ASSET_FACTORY_MODEL3D_MODEL=
# ASSET_FACTORY_AUDIO_MODEL=
# ASSET_FACTORY_OPENAI_VOICE=alloy
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Billing/observability placeholders.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# SENTRY_DSN=
