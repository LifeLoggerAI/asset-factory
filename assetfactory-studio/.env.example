# Asset Factory Studio local/development configuration

# Force local JSON/file storage even when Firebase Admin credentials are present.
ASSET_FACTORY_FORCE_LOCAL=true

# Optional Firebase Admin storage/persistence mode.
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# FIREBASE_STORAGE_BUCKET=

# Local development JWT signing secret. Replace in every real environment.
JWT_SECRET=change-me-local-only

# Media provider configuration. The current renderer produces deterministic proof
# assets locally. Set these when swapping in provider-backed adapters.
# ASSET_FACTORY_MEDIA_PROVIDER=local-proof
# OPENAI_API_KEY=
# REPLICATE_API_TOKEN=
# ELEVENLABS_API_KEY=
# STABILITY_API_KEY=
# FAL_KEY=

# Provider model IDs by modality.
# ASSET_FACTORY_GRAPHICS_MODEL=
# ASSET_FACTORY_MODEL3D_MODEL=
# ASSET_FACTORY_AUDIO_MODEL=

# Billing/observability placeholders.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# SENTRY_DSN=
