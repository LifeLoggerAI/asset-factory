rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function owns(ownerId) {
      return signedIn() && request.auth.uid == ownerId;
    }

    match /assets/{ownerId}/{jobId}/{filePath=**} {
      allow read: if owns(ownerId);
      allow write: if false;
    }

    match /bundles/{ownerId}/{bundleId}/{filePath=**} {
      allow read: if owns(ownerId);
      allow write: if false;
    }

    match /exports/{ownerId}/{exportJobId}/{filePath=**} {
      allow read: if owns(ownerId);
      allow write: if false;
    }

    match /previews/{ownerId}/{previewId}/{filePath=**} {
      allow read: if owns(ownerId);
      allow write: if false;
    }

    match /templates/{templateId}/{filePath=**} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /brand-kits/{ownerId}/{brandKitId}/{filePath=**} {
      allow read: if owns(ownerId);
      allow write: if false;
    }

    match /user_profiles/{userId}/profile_picture.jpg {
      allow read: if true;
      allow write: if owns(userId);
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
