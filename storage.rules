rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isUserAuthenticated() {
      return request.auth != null;
    }

    function isRequestingUser(userId) {
      return isUserAuthenticated() && request.auth.uid == userId;
    }

    function ownsExistingResource() {
      return isUserAuthenticated() && resource.data.ownerId == request.auth.uid;
    }

    function ownsRequestedResource() {
      return isUserAuthenticated() && request.resource.data.ownerId == request.auth.uid;
    }

    function ownsExistingUserResource() {
      return isUserAuthenticated() && resource.data.userId == request.auth.uid;
    }

    function ownsRequestedUserResource() {
      return isUserAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    function isPendingJobCreate() {
      return request.resource.data.status == 'pending'
        && request.resource.data.ownerId == request.auth.uid;
    }

    function hasAnonymousSession() {
      return request.resource.data.anonymousSessionId is string
        && request.resource.data.anonymousSessionId.size() >= 12;
    }

    function isSyntheticDemoDoc() {
      return resource.data.isSynthetic == true
        && resource.data.demoMode == true
        && resource.data.ownerId == 'synthetic-demo';
    }

    match /tenants/{tenantId} {
      allow read: if isRequestingUser(tenantId);
      allow write: if false;
    }

    match /jobs/{jobId} {
      allow read: if ownsExistingResource();
      allow create: if ownsRequestedResource() && isPendingJobCreate();
      allow update, delete: if false;
    }

    match /usage_ledger/{usageId} {
      allow read: if ownsExistingResource();
      allow write: if false;
    }

    match /dead_jobs/{jobId} {
      allow read: if ownsExistingResource();
      allow write: if false;
    }

    match /consent_ledger/{entryId} {
      allow read: if ownsExistingResource();
      allow create, update, delete: if false;
    }

    match /consent_snapshots/{snapshotId} {
      allow read: if ownsExistingResource();
      allow create, update, delete: if false;
    }

    match /feature_flags/{flagId} {
      allow read: if true;
      allow write: if false;
    }

    match /exports/{exportId} {
      allow read: if ownsExistingResource();
      allow create, update, delete: if false;
    }

    match /delete_requests/{requestId} {
      allow read: if ownsExistingResource();
      allow create: if ownsRequestedResource()
        && request.resource.data.status == 'requested'
        && request.resource.data.targetUserId == request.auth.uid;
      allow update, delete: if false;
    }

    match /demo_public/{demoId} {
      allow read: if isSyntheticDemoDoc();
      allow create, update, delete: if false;
    }

    match /timeline_events/{eventId} {
      allow read: if ownsExistingResource();
      allow write: if false;
    }

    match /narrator_reflections/{reflectionId} {
      allow read: if ownsExistingResource();
      allow write: if false;
    }

    match /assetFactoryRequests/{assetId} {
      allow read: if ownsExistingUserResource()
        || (
          resource.data.publicUrl is string
          && resource.data.lifecycleState == 'published'
        );

      allow create: if ownsRequestedUserResource()
        && request.resource.data.assetId == assetId
        && request.resource.data.status in ['requested', 'queued']
        && request.resource.data.lifecycleState in ['requested', 'queued'];

      allow update, delete: if false;
    }

    match /assetFactoryQueue/{queueId} {
      allow read: if ownsExistingUserResource();
      allow write: if false;
    }

    match /assetManifests/{assetId} {
      allow read: if true;
      allow write: if false;
    }

    match /publicAssets/{assetId} {
      allow read: if true;
      allow write: if false;
    }

    match /anonymousAssetRequests/{assetId} {
      allow create: if hasAnonymousSession()
        && request.resource.data.assetId == assetId
        && request.resource.data.status in ['requested', 'queued'];

      allow read, update, delete: if false;
    }

    match /lifeMapEvents/{eventId} {
      allow read: if ownsExistingUserResource();
      allow create: if ownsRequestedUserResource()
        && request.resource.data.eventId == eventId;
      allow update, delete: if false;
    }

    match /lifeMaps/{userId} {
      allow read: if isRequestingUser(userId);
      allow write: if false;
    }

    match /systemStatus/{statusId} {
      allow read: if statusId == 'asset-factory';
      allow write: if false;
    }

    match /system_metrics/{metricId} {
      allow read, write: if false;
    }

    match /billing_audit/{auditId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}