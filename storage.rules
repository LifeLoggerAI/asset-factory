rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function owns(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function validUpload(maxBytes) {
      return request.resource != null && request.resource.size < maxBytes;
    }

    match /assets/{userId}/{assetId}/{filePath=**} {
      allow read: if owns(userId);
      allow write: if owns(userId) && validUpload(26214400);
    }

    match /anonymousAssets/{sessionId}/{assetId}/{filePath=**} {
      allow read: if false;
      allow write: if sessionId.size() >= 12 && validUpload(26214400);
    }

    match /publicAssets/{assetId}/{filePath=**} {
      allow read: if true;
      allow write: if false;
    }

    match /user_profiles/{userId}/profile_picture.jpg {
      allow read: if true;
      allow write: if owns(userId) && validUpload(5242880);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
