{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://urai.app/schemas/full-multimodal-asset-manifest.schema.json",
  "title": "URAI Full Multimodal Asset Manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "manifestVersion",
    "generatedAt",
    "sourceLocks",
    "providerPolicy",
    "summary",
    "assets"
  ],
  "properties": {
    "schemaVersion": {"const": "1.2.0"},
    "manifestVersion": {"const": "1.2.0"},
    "generatedAt": {"type": "string", "format": "date-time"},
    "sourceLocks": {
      "type": "object",
      "required": ["assetFactoryHeadSha", "spatialMainSha", "specificationVersion"],
      "properties": {
        "assetFactoryHeadSha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "spatialMainSha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "specificationVersion": {"const": "1.2.0"}
      },
      "additionalProperties": false
    },
    "providerPolicy": {"type": "object"},
    "summary": {
      "type": "object",
      "required": ["total", "complete", "missingOrBlocked", "laneCounts", "statusCounts", "costUsedUsd", "costCeilingUsd"],
      "properties": {
        "total": {"type": "integer", "minimum": 0},
        "complete": {"type": "integer", "minimum": 0},
        "missingOrBlocked": {"type": "integer", "minimum": 0},
        "laneCounts": {"type": "object"},
        "statusCounts": {"type": "object"},
        "costUsedUsd": {"type": "number", "minimum": 0},
        "costCeilingUsd": {"type": "number", "minimum": 0}
      }
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "assetId", "lane", "category", "purpose", "audience", "format", "dimensions", "durationSeconds",
          "accessibilityVariants", "providerOrSource", "providerModelVersion", "licensingStatus", "commercialUseStatus",
          "consentRequirements", "likenessRequirements", "costCeilingUsd", "dependencies", "expectedOutputPath", "checksum",
          "provenance", "validationRequirements", "currentStatus", "reviewStatus", "promotionStatus", "promotionPr",
          "mergedCommitSha", "releaseSha", "generationRequest", "providerJobId", "generatedAt", "attemptCount",
          "costUsedUsd", "qualityReport", "artifactId", "artifactDigest", "runtimeRoute", "liveVerificationEvidence",
          "repository", "sourceRepository", "specificationVersion", "manifestVersion", "attributionRequirements",
          "sensitiveDataClassification", "ownershipStatus", "deletionPolicy", "retentionPolicy", "licenseExpiration",
          "exportabilityStatus", "revocationStatus", "rollbackSha", "releaseCertificationReceipt"
        ],
        "properties": {
          "assetId": {"type": "string", "minLength": 1},
          "lane": {"enum": ["image", "video", "audio", "3d", "xr", "accessibility", "review", "provenance"]},
          "category": {"type": "string", "minLength": 1},
          "purpose": {"type": "string", "minLength": 1},
          "audience": {"type": "array", "items": {"type": "string"}},
          "format": {"type": "array", "items": {"type": "string"}, "minItems": 1},
          "dimensions": {"type": ["object", "null"]},
          "durationSeconds": {"type": ["number", "null"], "minimum": 0},
          "accessibilityVariants": {"type": "array", "items": {"type": "string"}},
          "providerOrSource": {"type": "string"},
          "providerModelVersion": {"type": ["string", "null"]},
          "licensingStatus": {"enum": ["verified", "pending", "blocked", "not-applicable"]},
          "commercialUseStatus": {"enum": ["verified", "pending", "blocked", "not-applicable"]},
          "consentRequirements": {"type": "array", "items": {"type": "string"}},
          "likenessRequirements": {"type": "array", "items": {"type": "string"}},
          "costCeilingUsd": {"type": "number", "minimum": 0},
          "dependencies": {"type": "array", "items": {"type": "string"}},
          "expectedOutputPath": {"type": "string", "minLength": 1},
          "checksum": {"type": ["string", "null"]},
          "provenance": {"type": "object"},
          "validationRequirements": {"type": "array", "items": {"type": "string"}},
          "currentStatus": {"enum": ["required", "planned", "queued", "generating", "generated", "candidate", "blocked", "review-pending", "approved", "promoted", "certified", "removed-from-scope"]},
          "reviewStatus": {"enum": ["not-started", "pending", "approved", "rejected", "not-required"]},
          "promotionStatus": {"enum": ["not-started", "pr-open", "merged", "blocked"]},
          "promotionPr": {
            "type": ["string", "null"],
            "pattern": "^https://github\\.com/LifeLoggerAI/[A-Za-z0-9_.-]+/pull/[1-9][0-9]*$"
          },
          "mergedCommitSha": {"type": ["string", "null"]},
          "releaseSha": {"type": ["string", "null"]},
          "generationRequest": {"type": ["object", "null"]},
          "providerJobId": {"type": ["string", "null"]},
          "generatedAt": {"type": ["string", "null"]},
          "attemptCount": {"type": "integer", "minimum": 0},
          "costUsedUsd": {"type": "number", "minimum": 0},
          "qualityReport": {"type": ["object", "string", "null"]},
          "artifactId": {"type": ["string", "integer", "null"]},
          "artifactDigest": {"type": ["string", "null"]},
          "runtimeRoute": {"type": ["string", "null"]},
          "liveVerificationEvidence": {"type": "array", "items": {"type": "string"}},
          "repository": {"enum": ["LifeLoggerAI/asset-factory", "LifeLoggerAI/urai-spatial"]},
          "sourceRepository": {"enum": ["LifeLoggerAI/asset-factory", "LifeLoggerAI/urai-spatial"]},
          "specificationVersion": {"const": "1.2.0"},
          "manifestVersion": {"const": "1.2.0"},
          "attributionRequirements": {"type": "array", "items": {"type": "string"}},
          "sensitiveDataClassification": {"enum": ["none", "public", "internal", "confidential", "restricted"]},
          "ownershipStatus": {"enum": ["verified", "pending", "blocked", "not-applicable"]},
          "deletionPolicy": {"type": "string", "minLength": 1},
          "retentionPolicy": {"type": "string", "minLength": 1},
          "licenseExpiration": {"type": ["string", "null"]},
          "exportabilityStatus": {"enum": ["verified", "pending", "blocked", "not-applicable"]},
          "revocationStatus": {"enum": ["verified", "pending", "blocked", "not-applicable"]},
          "rollbackSha": {"type": ["string", "null"]},
          "releaseCertificationReceipt": {"type": ["object", "null"]}
        }
      }
    }
  },
  "additionalProperties": false
}
