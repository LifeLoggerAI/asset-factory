{
  "type": "object",
  "required": ["schemaVersion", "manifestId", "generatedAt", "sourceShas", "releasePolicy", "assets"],
  "properties": {
    "schemaVersion": {"const": "1.0.0"},
    "manifestId": {"type": "string", "minLength": 1},
    "generatedAt": {"type": "string"},
    "sourceShas": {
      "type": "object",
      "required": ["assetFactory", "spatial"],
      "properties": {
        "assetFactory": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "spatial": {"type": "string", "pattern": "^[0-9a-f]{40}$"}
      }
    },
    "releasePolicy": {
      "type": "object",
      "required": ["placeholdersAllowed", "requiresExactReleaseSha", "requiresLiveEvidence"],
      "properties": {
        "placeholdersAllowed": {"const": false},
        "requiresExactReleaseSha": {"const": true},
        "requiresLiveEvidence": {"const": true}
      }
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["assetId", "version", "experienceArea", "lane", "assetType", "routes", "runtimeComponent", "creativeSpecification", "technicalBudget", "providerOrSource", "licensingStatus", "consentRequirements", "costCeilingUsd", "dependencies", "expectedOutputPath", "checksum", "provenance", "validationRequirements", "currentStatus", "reviewStatus", "promotionStatus", "releaseSha"],
        "properties": {
          "assetId": {"type": "string", "minLength": 1},
          "version": {"type": "string"},
          "experienceArea": {"type": "string"},
          "lane": {"enum": ["visual", "3d", "audio", "film", "accessibility", "runtime", "governance"]},
          "assetType": {"type": "string"},
          "routes": {"type": "array", "items": {"type": "string"}},
          "runtimeComponent": {"type": "string"},
          "creativeSpecification": {"type": "string"},
          "technicalBudget": {"type": "object"},
          "providerOrSource": {"type": "string"},
          "licensingStatus": {"enum": ["verified", "pending", "blocked", "not-applicable"]},
          "consentRequirements": {"type": "array", "items": {"type": "string"}},
          "costCeilingUsd": {"type": "number", "minimum": 0},
          "dependencies": {"type": "array", "items": {"type": "string"}},
          "expectedOutputPath": {"type": "string"},
          "checksum": {"type": ["string", "null"]},
          "provenance": {"type": "object"},
          "validationRequirements": {"type": "array", "items": {"type": "string"}},
          "currentStatus": {"enum": ["missing", "candidate", "generated", "validated", "failed", "blocked", "certified", "removed-from-scope"]},
          "reviewStatus": {"enum": ["not-started", "pending", "approved", "rejected", "not-required"]},
          "promotionStatus": {"enum": ["not-started", "pr-open", "merged", "blocked"]},
          "releaseSha": {"type": ["string", "null"]}
        }
      }
    }
  }
}
