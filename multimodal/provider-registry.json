{
  "schemaVersion": "1.3.0",
  "policy": {
    "credentialsDoNotImplyExecutionReadiness": true,
    "paidRuntimeEnabled": false,
    "atomicOneTimeLedgerRequired": true,
    "atomicOneTimeLedgerConfigured": false,
    "environmentOnlyAuthorizationProhibited": true,
    "paidDispatchRequiresExactApproval": true,
    "paidDispatchRequiresExactHead": true,
    "paidDispatchRequiresAssetScope": true,
    "paidAuthorizationMustExpire": true,
    "duplicatePaidDispatchProhibited": true,
    "localProofIsNotProductionMedia": true,
    "planningInputEnv": [
      "ASSET_FACTORY_ENABLE_PAID_MEDIA",
      "ASSET_FACTORY_PAID_APPROVAL_ID",
      "ASSET_FACTORY_PAID_APPROVAL_SHA",
      "ASSET_FACTORY_PAID_AUTHORIZATION_EXPIRES_AT",
      "ASSET_FACTORY_PAID_ASSET_IDS",
      "ASSET_FACTORY_PAID_MAX_COST_CENTS"
    ],
    "planningInputsCannotAuthorizeDispatch": true
  },
  "providers": [
    {
      "name": "local-proof",
      "runtimeStatus": "implemented",
      "executionClass": "deterministic-proof-only",
      "paid": false,
      "supportedLanes": ["visual", "3d", "audio"]
    },
    {
      "name": "openai",
      "runtimeStatus": "implemented-http-runtime",
      "executionClass": "paid-fail-closed",
      "paid": true,
      "requiredCredentials": ["OPENAI_API_KEY"],
      "supportedLanes": ["visual", "audio"]
    },
    {
      "name": "replicate",
      "runtimeStatus": "implemented-http-runtime",
      "executionClass": "paid-fail-closed",
      "paid": true,
      "requiredCredentials": ["REPLICATE_API_TOKEN"],
      "requiredModelSelection": true,
      "supportedLanes": ["visual", "3d", "audio"]
    },
    {
      "name": "fal",
      "runtimeStatus": "implemented-http-runtime",
      "executionClass": "paid-fail-closed",
      "paid": true,
      "requiredCredentials": ["FAL_KEY"],
      "requiredModelSelection": true,
      "supportedLanes": ["visual", "3d", "audio"]
    },
    {
      "name": "elevenlabs",
      "runtimeStatus": "implemented-http-runtime",
      "executionClass": "paid-fail-closed-consent-required",
      "paid": true,
      "requiredCredentials": ["ELEVENLABS_API_KEY"],
      "supportedLanes": ["audio"]
    },
    {
      "name": "stability",
      "runtimeStatus": "implemented-http-runtime",
      "executionClass": "paid-fail-closed",
      "paid": true,
      "requiredCredentials": ["STABILITY_API_KEY"],
      "supportedLanes": ["visual"]
    }
  ]
}
