export const dynamic = "force-dynamic";
export const runtime = "nodejs";
export const revalidate = 0;

import path from "path";
import { NextRequest, NextResponse } from "next/server";
import { readGeneratedAsset } from "@/lib/server/assetFactoryStore";

export async function GET(
  _req: NextRequest,
  context: { params: { file: string } }
) {
  const fileName = path.basename(context.params.file);
  const result = await readGeneratedAsset(fileName);

  if (!result) {
    return NextResponse.json({ ok: false, error: "Generated asset not found", file: fileName }, { status: 404 });
  }

  return new NextResponse(new Uint8Array(result.data), {
    status: 200,
    headers: {
      "Content-Type": result.contentType,
      "Cache-Control": "no-store",
      "X-Asset-Factory-Persistence": result.persistenceMode,
    },
  });
}
