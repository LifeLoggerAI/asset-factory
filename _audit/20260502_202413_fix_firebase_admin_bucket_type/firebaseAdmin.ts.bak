import { getApps, initializeApp, applicationDefault, cert, type App } from "firebase-admin/app";
import { getFirestore, type Firestore } from "firebase-admin/firestore";
import { getStorage, type Bucket } from "firebase-admin/storage";

let adminApp: App | null = null;
let initializationError: string | null = null;
let fallbackReason: string | null = null;

function readServiceAccount() {
  const raw = process.env.FIREBASE_SERVICE_ACCOUNT_KEY || process.env.GOOGLE_APPLICATION_CREDENTIALS_JSON;
  if (!raw) return null;
  try {
    return JSON.parse(raw);
  } catch (error) {
    initializationError = error instanceof Error ? error.message : String(error);
    fallbackReason = "service-account-json-parse-failed";
    return null;
  }
}

function initAdmin(): App | null {
  if (adminApp) return adminApp;

  try {
    if (getApps().length > 0) {
      adminApp = getApps()[0] || null;
      return adminApp;
    }

    const projectId =
      process.env.FIREBASE_PROJECT_ID ||
      process.env.GCLOUD_PROJECT ||
      process.env.GOOGLE_CLOUD_PROJECT;

    const storageBucket =
      process.env.ASSET_FACTORY_STORAGE_BUCKET ||
      process.env.FIREBASE_STORAGE_BUCKET ||
      (projectId ? `${projectId}.appspot.com` : undefined);

    const serviceAccount = readServiceAccount();

    if (serviceAccount) {
      adminApp = initializeApp({
        credential: cert(serviceAccount),
        projectId: serviceAccount.project_id || projectId,
        storageBucket,
      });
      return adminApp;
    }

    if (projectId || process.env.K_SERVICE || process.env.FUNCTION_TARGET || process.env.FIREBASE_CONFIG) {
      adminApp = initializeApp({
        credential: applicationDefault(),
        projectId,
        storageBucket,
      });
      return adminApp;
    }

    fallbackReason = "no-production-or-service-account-admin-credentials";
    return null;
  } catch (error) {
    initializationError = error instanceof Error ? error.message : String(error);
    fallbackReason = "firebase-admin-initialization-failed";
    adminApp = null;
    return null;
  }
}

export function getAdminApp(): App | null {
  return initAdmin();
}

export function getAdminDb(): Firestore | null {
  const app = initAdmin();
  if (!app) return null;
  try {
    return getFirestore(app);
  } catch (error) {
    initializationError = error instanceof Error ? error.message : String(error);
    fallbackReason = "firestore-initialization-failed";
    return null;
  }
}

export function getAdminBucket(): Bucket | null {
  const app = initAdmin();
  if (!app) return null;
  try {
    return getStorage(app).bucket();
  } catch (error) {
    initializationError = error instanceof Error ? error.message : String(error);
    fallbackReason = "storage-bucket-initialization-failed";
    return null;
  }
}

export function isFirebaseAdminAvailable(): boolean {
  return Boolean(getAdminDb() && getAdminBucket());
}

export function getFirebaseAdminInitializationInfo() {
  const app = getAdminApp();
  const bucket = getAdminBucket();
  const projectId =
    app?.options.projectId ||
    process.env.FIREBASE_PROJECT_ID ||
    process.env.GCLOUD_PROJECT ||
    process.env.GOOGLE_CLOUD_PROJECT ||
    null;

  return {
    firebaseAdminAvailable: Boolean(app && bucket),
    fallbackActive: !(app && bucket),
    fallbackReason: app && bucket ? null : fallbackReason || "firebase-admin-unavailable",
    initializationError,
    firebaseProjectId: projectId,
    storageBucket:
      bucket?.name ||
      app?.options.storageBucket ||
      process.env.ASSET_FACTORY_STORAGE_BUCKET ||
      process.env.FIREBASE_STORAGE_BUCKET ||
      null,
    databaseId: "(default)",
  };
}
