{
  "name": "asset-factory-v1",
  "version": "1.0.1",
  "description": "A deterministic, API-driven asset generation pipeline.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "worker": "node asset_factory_worker.js",
    "test": "mocha 'test/**/*.js'",
    "asset:scaffold": "tsx asset-factory/tools/scaffold.ts",
    "asset:validate": "tsx asset-factory/tools/validate.ts",
    "asset:package": "tsx asset-factory/tools/package.ts",
    "asset:preview-index": "tsx asset-factory/tools/preview-index.ts",
    "asset:promote": "tsx asset-factory/tools/promote.ts",
    "asset:check-consumers": "tsx asset-factory/tools/check-consumers.ts",
    "asset-factory:local-e2e": "bash scripts/asset-factory-local-e2e.sh",
    "asset-factory:live-e2e": "bash scripts/asset-factory-live-e2e.sh",
    "asset-factory:deploy-hosting": "firebase deploy --only hosting --project asset-factory-dev-id",
    "asset-factory:deploy-function": "firebase deploy --only functions:assetFactory --project asset-factory-dev-id",
    "asset-factory:verify": "bash scripts/asset-factory-firestore-storage-verify.sh",
    "asset-factory:consumer-proof": "node scripts/urai-consumer-proof.mjs",
    "asset-factory:product-proof": "node scripts/asset-factory-product-system-proof.mjs",
    "asset-factory:raster-proof": "node scripts/asset-factory-raster-proof.mjs"
  },
  "keywords": [
    "asset",
    "generation",
    "deterministic"
  ],
  "author": "URAI",
  "license": "UNLICENSED",
  "dependencies": {
    "@radix-ui/themes": "^3.3.0",
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "archiver": "^5.3.1",
    "body-parser": "^1.19.0",
    "cors": "^2.8.5",
    "express": "^4.17.1",
    "fs-extra": "^10.0.0",
    "glob": "^8.1.0",
    "stripe": "^22.0.1",
    "uuid": "^9.0.0",
    "sharp": "0.33.5"
  },
  "devDependencies": {
    "@types/archiver": "^5.3.1",
    "@types/fs-extra": "^11.0.4",
    "@types/mocha": "^9.0.0",
    "@types/node": "^18.11.18",
    "@types/uuid": "^9.0.0",
    "chai": "^4.3.4",
    "esbuild": "^0.28.0",
    "mocha": "^9.0.0",
    "node-which": "^1.0.0",
    "ts-node": "^10.9.1",
    "tsx": "^4.7.2",
    "typescript": "^5.9.3",
    "which": "^6.0.1"
  },
  "engines": {
    "node": "22"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@firebase/util",
      "protobufjs",
      "sharp",
      "@img/sharp-linux-x64",
      "@img/sharp-libvips-linux-x64"
    ]
  }
}
