{
  "name": "asset-factory-root",
  "version": "1.0.0",
  "description": "Root dependencies for testing",
  "dependencies": {
    "firebase-admin": "^11.8.0",
    "firebase-functions": "^4.3.1",
    "stripe": "^14.5.0"
  },
  "private": true,
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10.8.0"
  },
  "scripts": {
    "doctor": "node scripts/doctor.mjs",
    "install:all": "node scripts/setup-local.mjs",
    "test": "pnpm --dir engine test && pnpm --dir life-map-pipeline/functions test && pnpm --dir functions test",
    "build": "pnpm --dir life-map-pipeline/functions run build && pnpm --dir functions run build",
    "verify:local": "corepack enable && corepack prepare pnpm@9.15.9 --activate && npm run image:install && npm run build && npm test --if-present && npm run test:launch-readiness --if-present && npm run test:completion-lock --if-present && npm run image:check",
    "verify:production": "npm run verify:local && npm run deploy:verify",
    "verify:launch": "node scripts/verify-asset-factory-launch.mjs",
    "test:launch-readiness": "npm run test:studio-deploy-readiness && npm run test:hs256-production-readiness && npm run test:privacy-safety-readiness && npm run test:support-smoke-readiness",
    "test:launch-readiness:legacy-static": "node scripts/test-launch-readiness.mjs",
    "test:studio-deploy-readiness": "node scripts/test-studio-deploy-readiness.mjs",
    "test:hs256-production-readiness": "node scripts/test-hs256-production-readiness.mjs",
    "test:privacy-safety-readiness": "node scripts/test-privacy-safety-readiness.mjs",
    "test:support-smoke-readiness": "node scripts/test-support-smoke-readiness.mjs",
    "test:implementation-audit-prompt": "node scripts/check-implementation-audit-prompt.mjs",
    "test:completion-lock": "node scripts/check-completion-lock.mjs && npm run test:implementation-audit-prompt",
    "check:release-evidence": "node scripts/check-release-evidence.mjs",
    "check:release-evidence:latest": "node scripts/check-latest-release-evidence.mjs",
    "check:deploy-workflow": "node scripts/check-deploy-workflow.mjs",
    "image:install": "python -m pip install -r image_asset_generator/requirements.txt",
    "image:manifest": "python image_asset_generator/validate_manifest.py",
    "image:generate": "python image_asset_generator/generate_assets.py",
    "image:validate": "python image_asset_generator/validate_assets.py",
    "image:preview": "python image_asset_generator/create_preview.py",
    "image:seed": "python image_asset_generator/create_firebase_seed.py",
    "image:export": "python image_asset_generator/export_assets.py",
    "image:check": "python image_asset_generator/run_pipeline.py",
    "audit:root": "test -f package-lock.json && npm audit --audit-level=high || echo 'Skipping root audit: package-lock.json is not committed yet. Run npm install --package-lock-only to enable root audit.'",
    "audit:functions": "npm --prefix life-map-pipeline/functions audit --audit-level=high || true",
    "audit:all": "npm run audit:root && npm run audit:functions",
    "lockfile:refresh-root": "npm install --package-lock-only && npm run audit:root",
    "lockfile:refresh-functions": "node scripts/refresh-functions-lockfile.mjs",
    "diagnose:custom-domain": "node scripts/diagnose-custom-domain.mjs",
    "deploy:firebase": "firebase deploy --project urai-4dc1d --only hosting,functions,firestore,storage",
    "deploy:hosting-rules": "firebase deploy --project urai-4dc1d --only hosting,firestore,storage",
    "deploy:functions": "firebase deploy --project urai-4dc1d --only functions",
    "deploy:studio": "npm --prefix assetfactory-studio run check && cd assetfactory-studio && firebase deploy --project urai-4dc1d --only hosting",
    "deploy:verify": "ASSET_FACTORY_BASE_URL=https://urai-4dc1d.web.app npm run smoke:production-finalization",
    "deploy:verify-readonly": "ASSET_FACTORY_BASE_URL=https://urai-4dc1d.web.app ASSET_FACTORY_SMOKE_READONLY=true npm run smoke:production-finalization",
    "deploy:verify-custom-domain": "ASSET_FACTORY_BASE_URL=https://www.uraiassetfactory.com ASSET_FACTORY_SMOKE_READONLY=true npm run smoke:production-finalization",
    "deploy:production": "npm run verify:local && npm run deploy:studio && npm run deploy:verify",
    "deploy:partial": "npm run verify:local && npm run deploy:hosting-rules && npm run deploy:verify-readonly",
    "smoke:remote": "node scripts/smoke-asset-factory-remote.mjs",
    "smoke:staging": "node scripts/smoke-asset-factory-remote.mjs",
    "smoke:prod": "node scripts/smoke-production-finalization.mjs",
    "smoke:production-finalization": "node scripts/smoke-production-finalization.mjs",
    "smoke:website": "ASSET_FACTORY_SMOKE_READONLY=true node scripts/smoke-production-finalization.mjs",
    "finish:custom-domain": "node scripts/finish-custom-domain-production.mjs"
  }
}
