{
  "name": "asset-factory-root",
  "version": "1.0.0",
  "description": "Root dependencies for testing",
  "dependencies": {
    "firebase-admin": "^11.8.0",
    "firebase-functions": "^4.3.1",
    "stripe": "^14.5.0"
  },
  "private": true,
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10.8.0"
  },
  "scripts": {
    "doctor": "node scripts/doctor.mjs",
    "test": "npm --prefix engine test && npm --prefix life-map-pipeline/functions test && npm --prefix functions test",
    "build": "npm --prefix life-map-pipeline/functions run build && npm --prefix functions run build",
    "test:launch-readiness": "node scripts/test-launch-readiness.mjs",
    "smoke:remote": "node scripts/smoke-asset-factory-remote.mjs",
    "smoke:staging": "node scripts/smoke-asset-factory-remote.mjs",
    "smoke:prod": "node scripts/smoke-asset-factory-remote.mjs",
    "smoke:website": "ASSET_FACTORY_SMOKE_READONLY=true node scripts/smoke-asset-factory-remote.mjs"
  }
}
