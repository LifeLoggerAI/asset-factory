{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://urai.app/schemas/asset-creative-approval-1.0.0.json",
  "title": "URAI Asset Creative Approval Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "version",
    "status",
    "humanReview",
    "reviewerType",
    "reviewer",
    "reviewedAt",
    "decisionNotes",
    "assetFactoryHeadSha",
    "handoffManifestSha256",
    "rightsLedgerSha256",
    "approvedAssets"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "version": { "enum": ["v1", "v2", "v3", "v4", "v5"] },
    "status": { "const": "approved" },
    "humanReview": { "const": true },
    "reviewerType": { "const": "human" },
    "reviewer": { "type": "string", "minLength": 2 },
    "reviewedAt": { "type": "string", "format": "date-time" },
    "decisionNotes": { "type": "string", "minLength": 8 },
    "assetFactoryHeadSha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "handoffManifestSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "rightsLedgerSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "approvedAssets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["canonicalPath", "sha256"],
        "properties": {
          "canonicalPath": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    }
  }
}
