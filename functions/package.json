{
  "name": "functions",
  "description": "Cloud Functions for Asset Factory",
  "scripts": {
    "serve": "firebase emulators:start --only functions,firestore,storage,auth",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions,firestore:rules,firestore:indexes,storage",
    "logs": "firebase functions:log",
    "build": "node --check index.js && node --check packaging.js",
    "test": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "main": "index.js",
  "dependencies": {
    "firebase-admin": "^11.8.0",
    "firebase-functions": "^4.3.1",
    "jszip": "^3.10.1",
    "stripe": "^14.5.0"
  },
  "devDependencies": {
    "firebase-functions-test": "^3.1.0"
  },
  "private": true
}
