rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owns(ownerId) {
      return signedIn() && request.auth.uid == ownerId;
    }

    function ownsExisting() {
      return signedIn() && resource.data.ownerId == request.auth.uid;
    }

    function ownsIncoming() {
      return signedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    function isServiceOnly() {
      return false;
    }

    match /users/{userId} {
      allow read: if owns(userId);
      allow write: if false;
    }

    match /tenants/{tenantId} {
      allow read: if owns(tenantId);
      allow write: if false;
    }

    match /subscriptions/{subscriptionId} {
      allow read: if ownsExisting();
      allow write: if false;
    }

    match /assetJobs/{jobId} {
      allow read: if ownsExisting();
      allow create: if ownsIncoming() && request.resource.data.status == 'PENDING';
      allow update, delete: if false;
      match /verifications/{verificationId} {
        allow read: if owns(/databases/$(database)/documents/assetJobs/$(jobId)).data.ownerId;
        allow write: if false;
      }
    }

    match /generatedAssets/{assetId} {
      allow read: if ownsExisting();
      allow write: if false;
    }

    match /assetBundles/{bundleId} {
      allow read: if ownsExisting();
      allow write: if false;
    }

    match /usageLedger/{usageId} {
      allow read: if ownsExisting();
      allow write: if false;
    }

    match /billingAudit/{auditId} {
      allow read, write: if false;
    }

    match /replayJobs/{replayJobId} {
      allow read: if ownsExisting();
      allow write: if false;
    }

    match /lifeMapInputs/{inputId} {
      allow read: if ownsExisting();
      allow write: if false;
    }

    match /templates/{templateId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /generatorPresets/{presetId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /brandKits/{brandKitId} {
      allow read: if ownsExisting();
      allow write: if false;
    }

    match /exportJobs/{exportJobId} {
      allow read: if ownsExisting();
      allow write: if false;
    }

    match /deadJobs/{jobId} {
      allow read: if ownsExisting();
      allow write: if false;
    }

    match /auditLogs/{logId} {
      allow read, write: if false;
    }

    match /adminActions/{actionId} {
      allow read, write: if false;
    }

    match /webhooks/{webhookId} {
      allow read, write: if false;
    }

    match /entitlements/{entitlementId} {
      allow read: if ownsExisting();
      allow write: if false;
    }

    match /systemMetrics/{metricId} {
      allow read, write: if false;
    }

    match /integrityMismatches/{mismatchId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
