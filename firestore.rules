rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owns(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function ownsExisting() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    function ownsRequested() {
      return signedIn() && request.resource.data.userId == request.auth.uid;
    }

    function hasAnonymousSession() {
      return request.resource.data.anonymousSessionId is string && request.resource.data.anonymousSessionId.size() >= 12;
    }

    match /tenants/{tenantId} {
      allow read: if owns(tenantId);
      allow write: if false;
    }

    match /jobs/{jobId} {
      allow read: if signedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid && request.resource.data.status == 'pending';
      allow update, delete: if false;
    }

    match /assetFactoryRequests/{assetId} {
      allow read: if ownsExisting() || (resource.data.publicUrl is string && resource.data.lifecycleState == 'published');
      allow create: if ownsRequested()
        && request.resource.data.assetId == assetId
        && request.resource.data.status in ['requested', 'queued']
        && request.resource.data.lifecycleState in ['requested', 'queued'];
      allow update, delete: if false;
    }

    match /assetFactoryQueue/{queueId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /assetManifests/{assetId} {
      allow read: if true;
      allow write: if false;
    }

    match /publicAssets/{assetId} {
      allow read: if true;
      allow write: if false;
    }

    match /anonymousAssetRequests/{assetId} {
      allow create: if hasAnonymousSession()
        && request.resource.data.assetId == assetId
        && request.resource.data.status in ['requested', 'queued'];
      allow read, update, delete: if false;
    }

    match /lifeMapEvents/{eventId} {
      allow read: if ownsExisting();
      allow create: if ownsRequested() && request.resource.data.eventId == eventId;
      allow update, delete: if false;
    }

    match /lifeMaps/{userId} {
      allow read: if owns(userId);
      allow write: if false;
    }

    match /systemStatus/{statusId} {
      allow read: if statusId == 'asset-factory';
      allow write: if false;
    }

    match /usage_ledger/{usageId} {
      allow read: if signedIn() && resource.data.ownerId == request.auth.uid;
      allow write: if false;
    }

    match /dead_jobs/{jobId} {
      allow read: if signedIn() && resource.data.ownerId == request.auth.uid;
      allow write: if false;
    }

    match /system_metrics/{metricId} {
      allow read, write: if false;
    }

    match /billing_audit/{auditId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
