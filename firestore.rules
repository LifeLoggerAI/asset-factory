rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isUserAuthenticated() {
      return request.auth != null;
    }

    function isRequestingUser(userId) {
      return isUserAuthenticated() && request.auth.uid == userId;
    }

    function validUpload(maxBytes) {
      return request.resource != null
        && request.resource.size < maxBytes;
    }

    function isAllowedAssetContentType() {
      return request.resource != null
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType.matches('application/json')
          || request.resource.contentType.matches('text/.*')
          || request.resource.contentType.matches('audio/.*')
          || request.resource.contentType.matches('video/.*')
        );
    }

    function isAllowedProfileImageContentType() {
      return request.resource != null
        && request.resource.contentType.matches('image/.*');
    }

    function isReasonableAssetUpload() {
      return validUpload(50 * 1024 * 1024)
        && isAllowedAssetContentType();
    }

    function isReasonableAnonymousAssetUpload() {
      return validUpload(25 * 1024 * 1024)
        && isAllowedAssetContentType();
    }

    function isReasonableProfileImageUpload() {
      return validUpload(5 * 1024 * 1024)
        && isAllowedProfileImageContentType();
    }

    match /assets/{ownerId}/{assetOrJobId}/{filePath=**} {
      allow read: if isRequestingUser(ownerId);
      allow write: if isRequestingUser(ownerId)
        && isReasonableAssetUpload();
    }

    match /exports/{ownerId}/{exportId}/{filePath=**} {
      allow read: if isRequestingUser(ownerId);
      allow write: if false;
    }

    match /synthetic-demo/{demoId}/{filePath=**} {
      allow read: if true;
      allow write: if false;
    }

    match /anonymousAssets/{sessionId}/{assetId}/{filePath=**} {
      allow read: if false;
      allow write: if sessionId.size() >= 12
        && isReasonableAnonymousAssetUpload();
    }

    match /publicAssets/{assetId}/{filePath=**} {
      allow read: if true;
      allow write: if false;
    }

    match /user_profiles/{userId}/profile_picture.jpg {
      allow read: if true;
      allow write: if isRequestingUser(userId)
        && isReasonableProfileImageUpload();
    }

    match /user_profiles/{userId}/{filePath=**} {
      allow read: if isRequestingUser(userId);
      allow write: if isRequestingUser(userId)
        && isReasonableProfileImageUpload();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}