{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://urai.app/schemas/urai_asset_manifest.schema.json",
  "title": "URAI Asset Manifest",
  "type": "object",
  "required": [
    "id",
    "slug",
    "title",
    "assetType",
    "symbolicCategory",
    "version",
    "status",
    "visibility",
    "permissions",
    "createdBy",
    "createdAt",
    "updatedAt",
    "tags",
    "dependencies",
    "compatibleScenes",
    "performanceTier",
    "mobileReady",
    "arReady",
    "vrReady",
    "xrReady",
    "spatialReady",
    "productionReady",
    "validation"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "slug": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "assetType": {
      "enum": ["image", "overlay", "svg", "texture", "material", "model-glb", "model-gltf", "particle-system", "spatial-scene", "audio-loop", "audio-cue", "voice", "animation", "lottie", "rive", "video", "prompt-template", "scene-manifest"]
    },
    "symbolicCategory": { "type": "string", "minLength": 1 },
    "visualLayer": { "type": "string" },
    "environment": { "type": "string" },
    "emotionalState": { "type": "string" },
    "moodWeather": { "type": "string" },
    "auraColor": { "type": "string" },
    "geometryType": { "type": "string" },
    "textureUrl": { "type": "string" },
    "normalMapUrl": { "type": "string" },
    "displacementMapUrl": { "type": "string" },
    "roughnessMapUrl": { "type": "string" },
    "modelUrl": { "type": "string" },
    "gltfUrl": { "type": "string" },
    "glbUrl": { "type": "string" },
    "audioUrl": { "type": "string" },
    "animationUrl": { "type": "string" },
    "videoUrl": { "type": "string" },
    "thumbnailUrl": { "type": "string" },
    "previewUrl": { "type": "string" },
    "fallbackAsset": { "type": "string" },
    "prompt": { "type": "string" },
    "sourcePrompt": { "type": "string" },
    "negativePrompt": { "type": "string" },
    "promptTemplateId": { "type": "string" },
    "generationModel": { "type": "string" },
    "seed": { "type": ["string", "number"] },
    "generationParams": { "type": "object" },
    "version": { "type": "string" },
    "status": { "enum": ["draft", "queued", "generating", "generated", "validating", "approved", "rejected", "published", "archived", "failed"] },
    "visibility": { "enum": ["private-user", "system", "admin", "public-demo", "public-marketing", "internal-only"] },
    "permissions": {
      "type": "object",
      "required": ["publicReadable", "adminOnly", "containsUserData", "sanitizedForDemo"],
      "properties": {
        "ownerId": { "type": "string" },
        "allowedUserIds": { "type": "array", "items": { "type": "string" } },
        "allowedRoles": { "type": "array", "items": { "type": "string" } },
        "publicReadable": { "type": "boolean" },
        "adminOnly": { "type": "boolean" },
        "containsUserData": { "type": "boolean" },
        "containsUserMemoryData": { "type": "boolean" },
        "sanitizedForDemo": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "ownerId": { "type": "string" },
    "createdBy": { "type": "string" },
    "approvedBy": { "type": "string" },
    "createdAt": { "type": "string" },
    "updatedAt": { "type": "string" },
    "approvedAt": { "type": "string" },
    "publishedAt": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "compatibleScenes": { "type": "array", "items": { "type": "string" } },
    "performanceTier": { "enum": ["mobile-low", "mobile-mid", "mobile-high", "desktop", "xr"] },
    "mobileReady": { "type": "boolean" },
    "arReady": { "type": "boolean" },
    "vrReady": { "type": "boolean" },
    "xrReady": { "type": "boolean" },
    "spatialReady": { "type": "boolean" },
    "productionReady": { "type": "boolean" },
    "validation": {
      "type": "object",
      "required": ["schemaValid", "filesExist", "urlsReachable", "noPlaceholderText", "noDebugText", "noPrivateData", "errors", "warnings"],
      "properties": {
        "schemaValid": { "type": "boolean" },
        "filesExist": { "type": "boolean" },
        "urlsReachable": { "type": "boolean" },
        "gltfValid": { "type": "boolean" },
        "audioValid": { "type": "boolean" },
        "imageOptimized": { "type": "boolean" },
        "noPlaceholderText": { "type": "boolean" },
        "noDebugText": { "type": "boolean" },
        "noPrivateData": { "type": "boolean" },
        "checkedAt": { "type": "string" },
        "errors": { "type": "array", "items": { "type": "string" } },
        "warnings": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
